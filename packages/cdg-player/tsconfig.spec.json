{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./.dist/out-tsc/spec",
    "tsBuildInfoFile": "./.dist/out-tsc/spec/tsconfig.spec.tsbuildinfo",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "vitest"
    ]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../cdg-loader/tsconfig.lib.json"
    },
    {
      "path": "../cdg-core/tsconfig.lib.json"
    }
  ]
}
