{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./.tsbuild/out-tsc/lib",
    "tsBuildInfoFile": "./.tsbuild/out-tsc/lib/tsconfig.lib.tsbuildinfo",
    "declaration": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../logger/tsconfig.lib.json"
    },
    {
      "path": "../media-core/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
