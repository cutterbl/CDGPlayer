{
  "name": "cdg-controls",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cdg-controls/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}/.dist"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cdg-controls",
        "command": "vite build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cdg-controls",
        "command": "vitest"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cdg-controls",
        "command": "eslint ."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cdg-controls",
        "command": "tsc --build --emitDeclarationOnly"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}/.dist"
      }
    }
  }
}
