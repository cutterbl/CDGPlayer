{
  "name": "cdgplayer",
  "private": true,
  "version": "0.1.17",
  "description": "A browser based HTML5/JS karaoke 'Player', that takes a zip file containing an mp3 and cdg file, allowing the user to render and play directly in the browser.",
  "main": "dist/cdgplayer.js",
  "module": "dist/cdgplayer.js",
  "keywords": [
    "cdg",
    "cd+g",
    "karaoke"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cutterbl/CDGPlayer.git"
  },
  "author": {
    "name": "Stephen G Blades, Jr (AKA 'Cutter')",
    "url": "http://cutterscrossing.com"
  },
  "license": "GPL-3.0-or-later",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "pnpm nx run-many -t build --exclude=cdgplayer",
    "ci:build": "pnpm nx run-many -t build --projects=cdg-core,cdg-loader,cdg-player,cdg-controls,demo,framework-demo --outputStyle=stream",
    "ci:docs": "pnpm run docs:check-required",
    "ci:perf": "pnpm run perf:generate-artifact && pnpm run perf:check-ci-artifact",
    "ci:release-readiness": "pnpm run release:readiness",
    "ci:test": "pnpm nx run-many -t test --projects=cdg-core,cdg-loader,cdg-player,cdg-controls,demo,framework-demo --outputStyle=stream",
    "ci:validate": "pnpm nx run-many -t lint,typecheck --projects=cdg-core,cdg-loader,cdg-player,cdg-controls,demo,framework-demo --outputStyle=stream && pnpm run docs:check-required",
    "dev": "pnpm nx dev demo",
    "dev:framework": "pnpm nx dev framework-demo",
    "docs:check-required": "node scripts/ci/check-docs.mjs",
    "lint": "pnpm nx run-many -t lint --exclude=cdgplayer",
    "perf:check-artifacts": "node scripts/ci/check-perf-readiness.mjs --require-artifacts",
    "perf:check-ci-artifact": "node scripts/ci/check-perf-readiness.mjs --require-artifacts --artifact artifacts/perf/ci-aggregated.json",
    "perf:check-readiness": "node scripts/ci/check-perf-readiness.mjs",
    "perf:generate-artifact": "node scripts/ci/generate-perf-artifact.mjs",
    "release:readiness": "node scripts/ci/check-release-readiness.mjs",
    "release": "pnpm nx release",
    "storybook": "pnpm run storybook:dev",
    "storybook:build": "pnpm nx run storybook-web:build && pnpm nx run storybook-react:build && STORYBOOK_BUILD=true pnpm nx run storybook-hub:build && node scripts/ci/assemble-storybook-site.mjs",
    "storybook:dev": "pnpm nx run-many -t dev --projects=storybook-web,storybook-react,storybook-hub --parallel=3 --outputStyle=stream",
    "storybook:hub": "pnpm nx run storybook-hub:dev",
    "storybook:react": "pnpm nx run storybook-react:dev",
    "storybook:web": "pnpm nx run storybook-web:dev",
    "start": "pnpm nx serve demo",
    "start:framework": "pnpm nx serve framework-demo",
    "test": "pnpm nx run-many -t test --exclude=cdgplayer",
    "typecheck": "pnpm nx run-many -t typecheck --exclude=cdgplayer",
    "watch": "pnpm nx run-many -t build --watch --exclude=cdgplayer"
  },
  "devDependencies": {
    "@commitlint/cli": "17.4.0",
    "@commitlint/config-conventional": "17.4.0",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/vite": "^22.6.4",
    "@nx/vitest": "22.6.4",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/web-components-vite": "^10.3.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "eslint": "~8.57.0",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.6.4",
    "prettier": "~3.6.2",
    "storybook": "^10.3.5",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "verdaccio": "^6.3.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=4.4.2"
    }
  },
  "nx": {
    "includedScripts": []
  },
  "packageManager": "pnpm@10.33.0"
}
