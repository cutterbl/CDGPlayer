{
  "name": "cdgplayer",
  "version": "0.1.17",
  "type": "module",
  "description": "A browser based HTML5/JS karaoke 'Player', that takes a zip file containing an mp3 and cdg file, allowing the user to render and play directly in the browser.",
  "main": "dist/cdgplayer.js",
  "module": "dist/cdgplayer.js",
  "keywords": [
    "cdg",
    "cd+g",
    "karaoke"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cutterbl/CDGPlayer.git"
  },
  "author": {
    "name": "Stephen G Blades, Jr (AKA 'Cutter')",
    "url": "http://cutterscrossing.com"
  },
  "license": "GPL-3.0-or-later",
  "files": [
    "dist/**/*",
    "index.html",
    "index.js",
    "server.js",
    "CDGPlayer.svg"
  ],
  "scripts": {
    "build": "rollup -c ./configs/rollup.config.mjs",
    "watch": "rollup -c ./configs/rollup.config.mjs --watch",
    "release": "standard-version",
    "start": "node ./scripts/server.js"
  },
  "devDependencies": {
    "@babel/core": "7.28.4",
    "@babel/eslint-parser": "7.28.4",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/preset-env": "7.28.3",
    "@commitlint/cli": "20.1.0",
    "@commitlint/config-conventional": "20.0.0",
    "@rollup/plugin-babel": "6.0.4",
    "@rollup/plugin-commonjs": "28.0.6",
    "@rollup/plugin-eslint": "9.1.0",
    "@rollup/plugin-html": "^2.0.0",
    "@rollup/plugin-node-resolve": "16.0.2",
    "@rollup/plugin-terser": "0.4.4",
    "autoprefixer": "10.4.21",
    "babel-eslint": "10.1.0",
    "connect": "3.7.0",
    "eslint": "9.37.0",
    "globals": "^16.4.0",
    "localip": "1.0.0",
    "open": "^10.2.0",
    "postcss": "8.5.6",
    "postcss-assets": "6.0.0",
    "prettier": "3.6.2",
    "regenerator-runtime": "0.14.1",
    "rollup": "4.52.4",
    "rollup-plugin-cleanup": "3.2.1",
    "rollup-plugin-clear": "2.0.7",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-string": "^3.0.0",
    "sass": "1.93.2",
    "serve-static": "2.2.0",
    "soundtouchjs": "0.2.1",
    "standard-version": "9.5.0"
  },
  "dependencies": {
    "jsmediatags": "3.9.7",
    "jszip": "3.10.1",
    "jszip-utils": "0.1.0"
  },
  "resolutions": {
    "tar": ">=4.4.2"
  }
}
