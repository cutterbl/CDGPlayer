{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./.dist/out-tsc/app",
    "tsBuildInfoFile": "./.dist/out-tsc/app/tsconfig.app.tsbuildinfo",
    "noEmit": false,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "references": [
    {
      "path": "../../packages/media-playback-controls/tsconfig.lib.json"
    },
    {
      "path": "../../packages/media-player/tsconfig.lib.json"
    }
  ]
}
