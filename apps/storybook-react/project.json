{
  "name": "storybook-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/storybook-react",
  "tags": ["type:docs", "runtime:react"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/storybook-react",
        "command": "storybook dev -p 4402 --config-dir .storybook --disable-telemetry"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/storybook-react",
        "command": "storybook build --config-dir .storybook --output-dir .dist --disable-telemetry"
      }
    }
  }
}
